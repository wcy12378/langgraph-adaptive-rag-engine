# ── OpenAI / LLM ─────────────────────────────────────────────
OPENAI_API_KEY=your-openai-api-key
OPENAI_API_BASE=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
LLM_PROVIDER=openai

# ── Anthropic (备用) ────────────────────────────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=

# ── Qdrant ───────────────────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=adaptive_rag
QDRANT_API_KEY=your-qdrant-api-key

# ── Retrieval ────────────────────────────────────────────────
TOP_K=4
SCORE_THRESHOLD=0.5
